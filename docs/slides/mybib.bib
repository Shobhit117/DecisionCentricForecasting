@inbook{snyder2019,
publisher = {Wiley},
isbn = {9781119584445},
title = {Stochastic Inventory Models: Periodic Review},
booktitle = {Fundamentals of Supply Chain Theory},
chapter = {4},
pages = {87-154},
doi = {https://doi.org/10.1002/9781119584445.ch4},
year = {2019},
keywords = {cycle stock, dynamic programming model, finite horizon, infinite-horizon, periodic-review models, safety stock, single-period model, stochastic inventory theory},
abstract = {Summary This chapter considers inventory models in which the demand is stochastic. It focuses on periodic-review models. The chapter first considers problems with no fixed costs and then problems with nonzero fixed costs. It assumes that unmet demands are backordered. The chapter discusses the lost-sales assumption. It introduces two important concepts in stochastic inventory theory: cycle stock and safety stock. A base-stock policy is optimal for the single-period problem with no fixed costs. The chapter examines how to determine the optimal s and S for the single-period, finite horizon, and infinite-horizon cases separately. The finite-horizon model with nonzero fixed costs can be solved using a straightforward modification of the dynamic programming model for the zero-fixed-cost case. The chapter presents formal proofs for the single-period and finite-horizon cases but only states the result without proof for the infinite-horizon case.}
}
